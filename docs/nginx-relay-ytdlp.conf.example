# ─────────────────────────────────────────────────────────────────────────────
# nginx-relay-ytdlp.conf — конфиг для relay-сервера (1-2-3-4.sslip.io)
#
# Назначение: проксировать /info/ и /dl/ на бот-сервер (2-2-2-2.sslip.io:7443)
# для пользователей у которых заблокированы Cloudflare Tunnel и прямой IP.
#
# Схема:
#   Клиент (RU, заблокирован) → relay:5443/info/<token>
#   nginx relay → https://2-2-2-2.sslip.io:7443/info/<token>
#   Страница /info/ имеет кнопку <a href="/dl/<token>"> (относительный URL)
#   Клиент нажимает → relay:5443/dl/<token> → бот-сервер:7443/dl/<token>
#
# Добавить в server { listen 5443 ssl; server_name 1-2-3-4.sslip.io; ... }
# ПЕРЕД блоком location / { ... }
#
# ─────────────────────────────────────────────────────────────────────────────

    # ─── yt-dlp: страница предпросмотра файла ─────────────────────────────────
    location /info/ {
        limit_except GET HEAD {
            deny all;
        }

        # Используем общую зону rate-limit (зона "one" уже определена в nginx.conf).
        # burst=10 — запас для одновременных запросов (предпросмотр + JS/CSS).
        limit_req zone=one burst=10 nodelay;

        proxy_pass                        https://2-2-2-2.sslip.io:7443;
        proxy_http_version                1.1;

        # TLS к бот-серверу (проверяем сертификат Let's Encrypt / sslip.io)
        proxy_ssl_protocols               TLSv1.2 TLSv1.3;
        proxy_ssl_server_name             on;
        proxy_ssl_name                    2-2-2-2.sslip.io;
        proxy_ssl_verify                  on;
        proxy_ssl_trusted_certificate     /etc/ssl/certs/ca-certificates.crt;
        proxy_ssl_session_reuse           on;

        proxy_set_header Host             2-2-2-2.sslip.io;
        proxy_set_header X-Real-IP        $remote_addr;
        proxy_set_header X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection       "";

        proxy_connect_timeout  10s;
        proxy_send_timeout     30s;
        proxy_read_timeout     30s;
    }

    # ─── yt-dlp: стриминг файла (скачивание) ──────────────────────────────────
    location /dl/ {
        limit_except GET HEAD {
            deny all;
        }

        # Токен одноразовый → перебор бессмысленен → rate limit мягкий
        limit_req zone=one burst=5 nodelay;

        proxy_pass                        https://2-2-2-2.sslip.io:7443;
        proxy_http_version                1.1;

        proxy_ssl_protocols               TLSv1.2 TLSv1.3;
        proxy_ssl_server_name             on;
        proxy_ssl_name                    2-2-2-2.sslip.io;
        proxy_ssl_verify                  on;
        proxy_ssl_trusted_certificate     /etc/ssl/certs/ca-certificates.crt;
        proxy_ssl_session_reuse           on;

        proxy_set_header Host             2-2-2-2.sslip.io;
        proxy_set_header X-Real-IP        $remote_addr;
        proxy_set_header X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection       "";

        # Без буферизации — файлы могут быть сотни МБ
        proxy_buffering         off;
        proxy_request_buffering off;

        proxy_connect_timeout  10s;
        proxy_send_timeout     300s;
        proxy_read_timeout     300s;
    }

# ─────────────────────────────────────────────────────────────────────────────
# nftables: открыть порт 5443 для всех (не только VPN-ASN)
#
# По умолчанию в vpn-proxy nftables порт 5443 открыт только для $ASN.
# Если relay должен быть доступен всем RU-пользователям — обновить правило:
#
#   Было:
#     meta mark $ASN tcp dport 5443 counter accept
#
#   Стало (добавить ПЕРЕД существующим $ASN-правилом):
#     tcp dport 5443 ct state new meter ytdlp_meter { ip saddr limit rate over 20/second burst 10 packets } drop
#     tcp dport 5443 counter accept
#
# Или (если хотите ограничить по-прежнему только RU-ASN, без глобального открытия):
#   Убедитесь что ASN-список включает нужные провайдеры (Ростелеком, МТС, Билайн и т.п.)
# ─────────────────────────────────────────────────────────────────────────────
