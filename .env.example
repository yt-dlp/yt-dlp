# ─────────────────────────────────────────────────────────────
#  YT-DLP Telegram Bot — конфигурация окружения
#  Скопируйте в .env и заполните значения.
#  НИКОГДА не коммитьте .env в git!
# ─────────────────────────────────────────────────────────────

# ── Обязательное ──────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=123456789:ABCDEFabcdefABCDEF1234567890abcdef

# Ваш числовой Telegram user ID (найти через @userinfobot)
# Несколько администраторов — через запятую: 111111,222222
ADMIN_IDS=123456789

# ── Локальный Telegram Bot API сервер (ОБЯЗАТЕЛЬНО для файлов > 50 МБ) ────────
# Получите на https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# URL локального сервера (при использовании docker-compose — не менять)
LOCAL_API_SERVER=http://telegram-bot-api:8081

# ── Контроль доступа ──────────────────────────────────────────
# "closed" — администратор одобряет каждого пользователя вручную (рекомендуется)
# "open"   — любой, кто написал боту, получает доступ
REGISTRATION_MODE=closed

# ── Лимиты загрузки ───────────────────────────────────────────
# Максимальный размер файла в МБ
# С локальным Bot API сервером — до 10240 МБ (10 ГБ)
# Без локального сервера — максимум 50 МБ (жёсткий лимит Telegram)
MAX_FILE_SIZE_MB=10240

# Таймаут загрузки в секундах (для больших файлов увеличьте)
DOWNLOAD_TIMEOUT=3600

# Максимальное количество одновременных загрузок
MAX_CONCURRENT_DOWNLOADS=3

# ── Пути (должны совпадать с volume mounts в docker-compose.yml) ─
DOWNLOAD_DIR=/downloads
DB_PATH=/data/bot.db

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Токен Named Tunnel из Cloudflare Dashboard → Zero Trust → Networks → Tunnels.
# Оставьте пустым для Quick Tunnel (временный URL, только для теста).
CLOUDFLARE_TUNNEL_TOKEN=

# ── Файловый HTTP-сервер (раздача ссылок вместо загрузки в Telegram) ──────────
# Публичный адрес через Cloudflare Tunnel (без trailing slash).
# Если задан — бот предлагает кнопку «🔗 Ссылка через Cloudflare».
# С Cloudflare Named Tunnel: https://ваш-поддомен.domain.com
# С Cloudflare Quick Tunnel: смотрите docker compose logs cloudflared
PUBLIC_BASE_URL=

# Прямой HTTPS-адрес сервера через nginx-ssl (без trailing slash).
# Если задан — бот предлагает кнопку «🌐 Прямая ссылка с сервера».
# Используется с sslip.io (технический домен для IP без своего домена).
# Пример: https://15-24-9-1.sslip.io:7443
# Можно использовать одновременно с PUBLIC_BASE_URL — будут 3 кнопки:
#   📤 Telegram | 🔗 Cloudflare | 🌐 С сервера
DIRECT_BASE_URL=

# Relay-сервер — резервный путь для пользователей у которых заблокирован Cloudflare
# и/или прямой IP. Второй сервер (например в RU) проксирует /info/ и /dl/ на бот-сервер.
# При установке добавляется 4-я кнопка: 🔄 Relay-ссылка
# Пример: https://1-2-3-4.sslip.io:5443
# На relay-сервере нужно добавить location в nginx (см. docs/nginx-relay-ytdlp.conf.example)
RELAY_BASE_URL=

# Порт внутреннего HTTP-сервера (файловый сервер внутри ytdlp-bot)
HTTP_PORT=8080

# ── Nginx SSL (прямой HTTPS по IP, профиль "ssl") ─────────────────────────────
# Для включения: COMPOSE_PROFILES=ssl (в .env или при запуске)
#
# Технический домен через sslip.io: A-B-C-D.sslip.io → A.B.C.D
# Обязателен для nginx-ssl контейнера. БЕЗ порта — только домен.
SSLIP_DOMAIN=15-24-9-1.sslip.io

# Порт HTTPS для прямого доступа (443 занят — используем 7443)
HTTPS_PORT=7443

# Let's Encrypt: включить/выключить автоматическое получение сертификата.
# Для LE cert нужен порт 80 доступный извне (nftables DNAT → 10.10.2.5:80).
# Перенаправьте порт 80 вручную перед первым запуском, затем можете убрать.
# При ENABLE_CERTBOT=false — используется self-signed cert (шифрование есть).
ENABLE_CERTBOT=true

# Email для Let's Encrypt (необязателен).
# Если пуст — certbot работает без email (--register-unsafely-without-email).
# С email — LE пришлёт уведомление если сертификат истекает.
CERTBOT_EMAIL=

# Активация nginx-ssl контейнера (раскомментировать для включения)
#COMPOSE_PROFILES=ssl

# Время жизни ссылки в часах (файл удаляется после скачивания или по истечению)
FILE_TTL_HOURS=1

# Секретный ключ для HMAC-подписи токенов файлового сервера (рекомендуется!)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
SERVER_SECRET=

# ── Функции ─────────────────────────────────────────────────────
ALLOW_PLAYLISTS=true
ALLOW_AUDIO=true
ALLOW_SUBTITLES=true
# Аудио в формате OPUS — ремукс без перекодирования, значительно быстрее MP3.
# YouTube хранит аудио уже в OPUS, поэтому конвертации не требуется.
ALLOW_OPUS=true
# Аудио в формате WAV (несжатый PCM) — без потерь, максимальное качество.
# Внимание: файлы очень большие (~10 МБ на минуту). Отключено по умолчанию.
ALLOW_WAV=false
# Максимальное количество видео в плейлисте.
# Кнопки меню покажут N÷2 и N видео на выбор.
MAX_PLAYLIST_ITEMS=10
# Ускорение загрузки через aria2c (16 параллельных соединений)
# Требует aria2 (уже установлен в Docker-образе)
USE_ARIA2C=true
# Автоматическое удаление рекламных вставок из YouTube (SponsorBlock)
USE_SPONSORBLOCK=false

# ── Webhook (альтернатива polling) ───────────────────────────────
# Если задан — бот использует webhook вместо polling.
# WEBHOOK_URL — публичный HTTPS-адрес бота (без trailing slash).
# Пример с Cloudflare Named Tunnel: https://bot.example.com
# Оставьте пустым чтобы использовать polling (режим по умолчанию).
WEBHOOK_URL=
# Порт для приёма webhook-запросов (отдельный от файлового сервера HTTP_PORT=8080)
WEBHOOK_PORT=8443
# Секрет для верификации webhook-запросов от Telegram (рекомендуется задать)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET_TOKEN=

# ── Мониторинг диска ─────────────────────────────────────────────
# Процент заполнения диска, при котором бот отправит алерт всем администраторам.
# Алерт повторяется не чаще 1 раза в 4 часа. 0 — выключено.
DISK_ALERT_THRESHOLD=80

# ── Опциональное ──────────────────────────────────────────────
# HTTP/SOCKS прокси (оставить пустым для отключения)
PROXY_URL=

# Путь к файлу куки (Netscape-формат) для контента 18+
# (монтируется как read-only в docker-compose.yml)
COOKIES_FILE=

# Авто-удаление сообщений бота после завершения загрузки (секунды).
# 0 — выключено. Пример: AUTO_DELETE_SECONDS=300 → удаляет через 5 мин.
AUTO_DELETE_SECONDS=0
