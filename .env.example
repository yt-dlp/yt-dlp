# ─────────────────────────────────────────────────────────────
#  YT-DLP Telegram Bot — конфигурация окружения
#  Скопируйте в .env и заполните значения.
#  НИКОГДА не коммитьте .env в git!
# ─────────────────────────────────────────────────────────────

# ── Обязательное ──────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=123456789:ABCDEFabcdefABCDEF1234567890abcdef

# Ваш числовой Telegram user ID (найти через @userinfobot)
# Несколько администраторов — через запятую: 111111,222222
ADMIN_IDS=123456789

# ── Локальный Telegram Bot API сервер (ОБЯЗАТЕЛЬНО для файлов > 50 МБ) ────────
# Получите на https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# URL локального сервера (при использовании docker-compose — не менять)
LOCAL_API_SERVER=http://telegram-bot-api:8081

# ── Контроль доступа ──────────────────────────────────────────
# "closed" — администратор одобряет каждого пользователя вручную (рекомендуется)
# "open"   — любой, кто написал боту, получает доступ
REGISTRATION_MODE=closed

# ── Лимиты загрузки ───────────────────────────────────────────
# Максимальный размер файла в МБ
# С локальным Bot API сервером — до 2000 МБ (2 ГБ)
# Без локального сервера — максимум 50 МБ (жёсткий лимит Telegram)
MAX_FILE_SIZE_MB=1600

# Таймаут загрузки в секундах (для больших файлов увеличьте)
DOWNLOAD_TIMEOUT=3600

# Максимальное количество одновременных загрузок
MAX_CONCURRENT_DOWNLOADS=3

# ── Пути (должны совпадать с volume mounts в docker-compose.yml) ─
DOWNLOAD_DIR=/downloads
DB_PATH=/data/bot.db

# ── Функции ─────────────────────────────────────────────────────
ALLOW_PLAYLISTS=true
ALLOW_AUDIO=true
ALLOW_SUBTITLES=true

# ── Опциональное ──────────────────────────────────────────────
# HTTP/SOCKS прокси (оставить пустым для отключения)
PROXY_URL=

# Путь к файлу куки (Netscape-формат) для контента 18+
# (монтируется как read-only в docker-compose.yml)
COOKIES_FILE=
