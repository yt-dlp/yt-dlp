# ─────────────────────────────────────────────────────────────
#  YT-DLP Telegram Bot — environment configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Get a token from @BotFather on Telegram
BOT_TOKEN=123456789:ABCDEFabcdefABCDEF1234567890abcdef

# Your Telegram numeric user ID (find it via @userinfobot)
# Multiple admins: comma-separated, e.g. 111111,222222
ADMIN_IDS=123456789

# ── Access control ────────────────────────────────────────────
# "closed" — admin approves each user manually (recommended)
# "open"   — anyone who messages the bot gets access
REGISTRATION_MODE=closed

# ── Download limits ───────────────────────────────────────────
# Maximum file size the bot will upload to Telegram (MB)
# Telegram hard limit is 50 MB for bots
MAX_FILE_SIZE_MB=50

# Download timeout in seconds
DOWNLOAD_TIMEOUT=600

# Maximum simultaneous downloads
MAX_CONCURRENT_DOWNLOADS=3

# ── Paths (match the volume mounts in docker-compose.yml) ─────
DOWNLOAD_DIR=/downloads
DB_PATH=/data/bot.db

# ── Feature flags ──────────────────────────────────────────────
ALLOW_PLAYLISTS=true
ALLOW_AUDIO=true
ALLOW_SUBTITLES=true

# ── Optional ──────────────────────────────────────────────────
# HTTP/SOCKS proxy (leave empty to disable)
PROXY_URL=

# Path to a Netscape-format cookies file for age-restricted videos
# (mount it read-only in docker-compose.yml)
COOKIES_FILE=
